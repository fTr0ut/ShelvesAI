{
    "cli": {
        "version": ">= 5.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            },
            "env": {
                "EXPO_PUBLIC_USE_NGROK": "true",
                "EXPO_PUBLIC_NGROK_URL": "https://nonresilient-rylan-nondebilitating.ngrok-free.dev"
            }
        },
        "preview": {
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_USE_NGROK": "false",
                "EXPO_PUBLIC_API_BASE": "https://api.shelvesai.com"
            }
        },
        "production": {
            "env": {
                "EXPO_PUBLIC_USE_NGROK": "false",
                "EXPO_PUBLIC_API_BASE": "https://api.shelvesai.com"
            },
            "autoIncrement": true
        }
    }
}
