{
  "expo": {
    "name": "ShelvesAI",
    "slug": "shelves-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "shelvesai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F1EA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shelvesai.app",
      "associatedDomains": [
        "applinks:shelvesai.com",
        "applinks:www.shelvesai.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Shelves.AI to capture your shelves.",
        "NSPhotoLibraryUsageDescription": "Allow Shelves.AI to import shelf photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-android.png",
        "backgroundColor": "#F4F1EA"
      },
      "package": "com.shelvesai.app",
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shelvesai.com",
              "pathPrefix": "/app"
            },
            {
              "scheme": "https",
              "host": "www.shelvesai.com",
              "pathPrefix": "/app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shelvesai.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "www.shelvesai.com",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Shelves.AI to access your collection photos.",
          "cameraPermission": "Allow Shelves.AI to capture your shelves."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "shelvesai",
          "organization": "trout-pond-llc"
        }
      ],
      [
        "@sentry/react-native"
      ]
      
    ],
    "extra": {
      "eas": {
        "projectId": "fc24bb32-ca24-4e79-b843-c87916d0f3de"
      }
    }
  }
}
