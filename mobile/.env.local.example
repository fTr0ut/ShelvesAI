# ===========================================
# LOCAL DEVELOPMENT OVERRIDES
# ===========================================
# Copy this file to .env.local for local dev:
#   cp .env.local.example .env.local
#
# Used by `npm run dev:local` to connect the
# mobile app to your local API server.
# ===========================================

# Address of your local API server.
# Use localhost for emulators, or your machine's LAN IP for physical devices.
# Examples:
#   http://localhost:5001          (iOS simulator / web)
#   http://10.0.2.2:5001           (Android emulator)
#   http://192.168.1.100:5001      (physical device on same network)
LOCAL_API_ADDRESS=http://localhost:5001
