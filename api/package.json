{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "nodemon index.js",
        "dev:local": "cross-env NODE_ENV=development USE_LOCAL_DB=1 nodemon index.js",
        "test:backend": "jest --config jest.config.js",
        "build-indexes": "node scripts/build-indexes.js",
        "audit:login-identifiers": "node scripts/audit-login-identifier-collisions.js",
        "backfill:feed-aggregates": "node scripts/backfill-event-aggregates.js",
        "backfill:feed-payloads": "node scripts/backfill-event-payloads.js",
        "upsert_collectables": "node -r dotenv/config scripts/upsert_collectables.js --file scripts/2024_2025.jsonl --collection collectables --batch 2000",
        "cache-covers": "node scripts/cache-collectable-covers.js",
        "backfill:cover-media": "node scripts/backfill-missing-cover-media.js",
        "backfill:collectable-cast": "node scripts/backfill-collectable-cast-members.js",
        "backfill:collectable-platform-data": "node scripts/backfill-collectable-platform-data.js",
        "db:local:check": "node scripts/init-local-db.js --check",
        "db:local:stamp-migrations": "cross-env USE_LOCAL_DB=1 node scripts/stamp-local-knex-migrations.js",
        "db:local:patch-favorites-manual-id": "cross-env USE_LOCAL_DB=1 node scripts/patch-local-user-favorites-manual-id.js",
        "db:local:reset": "node scripts/init-local-db.js",
        "test:tmdb": "node scripts/test-tmdb.js",
        "generate-token": "node scripts/generate-token.js",
        "init-db": "node scripts/init-db.js",
        "init-db:check": "node scripts/init-db.js --check",
        "init-db:fresh": "node scripts/init-db.js --fresh",
        "restore-db": "node scripts/restore-db.js",
        "migrate:local": "cross-env USE_LOCAL_DB=1 npx knex migrate:latest",
        "seed:local": "cross-env USE_LOCAL_DB=1 npx knex seed:run"
    },
    "keywords": [],
