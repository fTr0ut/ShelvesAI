        "multer": "^2.0.2",
        "node-fetch": "^2.7.0",
        "openai": "^4.54.0",
        "pg": "^8.16.3",
        "resend": "^6.9.4",
        "sharp": "^0.34.5",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
