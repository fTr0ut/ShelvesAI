# ===========================================
# LOCAL DEVELOPMENT OVERRIDES
# ===========================================
# Copy this file to .env.local for local dev:
#   cp .env.local.example .env.local
#
# Values here override anything in .env.
# .env.local is gitignored — safe for local secrets.
# ===========================================

NODE_ENV=development

# ===========================================
# LOCAL DATABASE (docker-compose)
# ===========================================
DATABASE_URL=postgresql://shelves:localdev123@localhost:5432/shelvesai
POSTGRES_URL=postgresql://shelves:localdev123@localhost:5432/shelvesai
POSTGRES_SSL=false

# ===========================================
# LOCAL AUTH
# ===========================================
JWT_SECRET=local-dev-secret-minimum-32-characters-long

# ===========================================
# SERVER
# ===========================================
PORT=5001

# ===========================================
# VISION SCAN IMAGE LIMITS (private scan-photo persistence)
# ===========================================
# Modern phone photos can exceed 4096 on one edge; vision scans use these overrides.
# Keep both limits to guard memory/CPU during decode.
VISION_SCAN_MAX_DIMENSION=8192
VISION_SCAN_MAX_PIXELS=40000000
VISION_CROP_WARMUP_ENABLED=true
VISION_CROP_WARMUP_MAX_REGIONS=50
# Gemini "other" shelf extraction budgets
VISION_OTHER_FIRST_PASS_THINKING_BUDGET=800
VISION_OTHER_SECOND_PASS_THINKING_BUDGET=2200
# Pixel padding applied before persisting Gemini vision regions (future scans)
VISION_BBOX_PADDING_X_PX=48
VISION_BBOX_PADDING_Y_PX=24
