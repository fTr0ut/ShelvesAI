# ===========================================
# DATABASE
# ===========================================
# Option 1: Connection URL (preferred for production)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Individual variables (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shelvesai
DB_USER=shelves
DB_PASSWORD=localdev123
DB_POOL_MAX=20
DB_SSL=false

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=your-very-long-secret-key-here-minimum-32-chars

# ===========================================
# GOOGLE CLOUD VISION
# ===========================================
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json
GOOGLE_GEN_AI_KEY=your-gemini-api-key


# ===========================================
# OPENAI (for catalog enrichment)
# ===========================================
OPENAI_API_KEY=sk-...
OPENAI_TEXT_MODEL=gpt-4o-mini

# ===========================================
# CATALOG APIs
# ===========================================
TMDB_API_KEY=your-tmdb-api-key

# Discogs (authenticated mode)
# Prefer personal token auth for server-to-server lookups.
DISCOGS_USER_TOKEN=your-discogs-user-token
# Optional alternative auth pair (used if token is not set)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
# Optional tuning
DISCOGS_TIMEOUT_MS=10000
DISCOGS_RETRIES=2
DISCOGS_RATE_LIMIT_PER_MINUTE=55

# IGDB (via Twitch)
IGDB_CLIENT_ID=your-twitch-client-id
IGDB_CLIENT_SECRET=your-twitch-client-secret

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_SHELF_VISION_SECOND_PASS=true

# ===========================================
# VISION THINKING BUDGETS (Gemini "other" shelf extraction)
# ===========================================
# First pass: broad detection + grounded metadata extraction for "other" shelves.
VISION_OTHER_FIRST_PASS_THINKING_BUDGET=800
# Second pass: low-confidence retry path for "other" shelves only.
VISION_OTHER_SECOND_PASS_THINKING_BUDGET=2200

# ===========================================
# VISION QUOTA
# ===========================================
VISION_MONTHLY_QUOTA=50
VISION_MONTHLY_TOKEN_QUOTA=500000
VISION_MAX_OUTPUT_TOKENS_PER_USER=100000

# ===========================================
# VISION CROP PADDING (persisted region bbox expansion)
# ===========================================
# Pixel padding applied to normalized Gemini box_2d before persisting
# vision_item_regions.box_2d (future scans only).
VISION_BBOX_PADDING_X_PX=48
VISION_BBOX_PADDING_Y_PX=24

# ===========================================
# FEED AGGREGATION
# ===========================================
FEED_AGGREGATE_WINDOW_MINUTES=15
FEED_AGGREGATE_PREVIEW_LIMIT=5
FEED_EVENT_ITEM_ID_CAP=250
FEED_AGGREGATE_DEBUG=false

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@shelvesai.com
RESEND_AUDIENCE_ID=aud_your-audience-id
APP_NAME=ShelvesAI
APP_URL=https://shelvesai.com
RESET_PASSWORD_URL=https://shelvesai.com/reset-password
RESET_PASSWORD_DEEP_LINK_BASE=shelvesai://reset-password

# ===========================================
# AWS S3 (Media Storage)
# ===========================================
# Leave blank to use local filesystem storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=shelvesai-media
# Use CloudFront CDN URL for better performance, or standard S3 URL
# S3_PUBLIC_URL=https://d123xyz.cloudfront.net
S3_PUBLIC_URL=https://shelvesai-media.s3.amazonaws.com

# ===========================================
# SERVER
# ===========================================
PORT=5001
NODE_ENV=development
