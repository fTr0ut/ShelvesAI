# API URL when running against production (used by `npm run dev`)
VITE_API_URL=/api

# API proxy target (used by Vite dev server to forward /api/* requests)
# For local API development, use `npm run dev:local` instead of editing this file.
# That command loads .env.localdev which points to http://localhost:5001.
API_TARGET=https://api.shelvesai.com
